{
  "ConnectionStrings": {
    "Default": "Data Source=bala.db"
  },
  "ArticleCache": {
    "MaxAgeMinutes": 1440,
    "AllowStaleOnError": true
  },
  "Extraction": {
    "NavigationTimeoutMs": 25000,
    "MaxRetries": 2,
    "RetryDelayMs": 500
  },
  "RateLimiting": {
    "PermitLimit": 60,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
